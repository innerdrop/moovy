generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserRoleType {
  USER
  ADMIN
  COMERCIO
  DRIVER
  SELLER
}

enum DeliveryType {
  IMMEDIATE
  SCHEDULED
}

enum DeliveryStatus {
  DRIVER_ASSIGNED
  DRIVER_ARRIVED
  PICKED_UP
  DELIVERED
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String
  name               String?
  firstName          String?
  lastName           String?
  phone              String?
  role               String              @default("USER")
  emailVerified      DateTime?
  image              String?
  pointsBalance      Int                 @default(0)
  pendingBonusPoints Int                 @default(0)
  bonusActivated     Boolean             @default(false)
  referralCode       String              @unique @default(cuid())
  referredById       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  privacyConsentAt   DateTime?
  termsConsentAt     DateTime?
  resetToken         String?
  resetTokenExpiry   DateTime?
  deletedAt          DateTime?
  addresses          Address[]
  cart               CartItem[]
  driver             Driver?
  ownedMerchants     Merchant[]
  orders             Order[]
  pointsTransactions PointsTransaction[]
  pushSubscriptions  PushSubscription[]
  referralsReceived  Referral?           @relation("ReferralReferee")
  referralsMade      Referral[]          @relation("ReferralReferrer")
  supportChats       SupportChat[]       @relation("UserSupportChats")
  sentSupportMsgs    SupportMessage[]    @relation("SupportMessageSender")
  referredBy         User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referredUsers      User[]              @relation("UserReferrals")
  roles              UserRole[]
  sellerProfile      SellerProfile?
  sellerAvailability SellerAvailability?
  favorites          Favorite[]
  auditLogs          AuditLog[]             @relation("AuditLogs")
  couponUsages       CouponUsage[]
  supportOperator    SupportOperator?
  orderChatsAsA      OrderChat[]         @relation("OrderChatParticipantA")
  orderChatsAsB      OrderChat[]         @relation("OrderChatParticipantB")
  orderChatMessages  OrderChatMessage[]  @relation("OrderChatMessageSender")
}

model UserRole {
  id          String       @id @default(cuid())
  userId      String
  role        UserRoleType
  isActive    Boolean      @default(true)
  activatedAt DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String   // Public key for encryption
  auth      String   // Auth secret for encryption
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model Address {
  id           String    @id @default(cuid())
  userId       String
  label        String
  street       String
  number       String
  apartment    String?
  neighborhood String?
  city         String    @default("Ushuaia")
  province     String    @default("Tierra del Fuego")
  zipCode      String?
  latitude     Float?
  longitude    Float?
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
}

model HeroSlide {
  id           String   @id @default(cuid())
  title        String          // kept for alt text / accessibility
  subtitle     String          // kept for SEO
  buttonText   String          // kept for optional CTA overlay
  buttonLink   String          // link when clicking the banner
  gradient     String   @default("from-[#e60012] via-[#ff2a3a] to-[#ff6b6b]")
  image        String?         // legacy field
  imageDesktop String?         // NEW: 1440x500 WebP banner for desktop
  imageMobile  String?         // NEW: 800x800 WebP banner for mobile
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id                      String             @id @default(cuid())
  name                    String             @unique
  slug                    String             @unique
  description             String?
  image                   String?
  isActive                Boolean            @default(true)
  order                   Int                @default(0)
  scope                   String             @default("BOTH") // STORE, MARKETPLACE, BOTH
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  allowIndividualPurchase Boolean            @default(true)
  price                   Float              @default(0)
  starterPrice            Float?             // Precio del starter pack (subset curado)
  isStarter               Boolean            @default(false) // Si es un starter pack curado
  parentId                String?
  icon                    String?
  parent                  Category?          @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children                Category[]         @relation("CategoryHierarchy")
  merchants               MerchantCategory[]
  products                ProductCategory[]
  listings                Listing[]
  packagePurchases        PackagePurchase[]
}

model Product {
  id          String                    @id @default(cuid())
  name        String
  slug        String                    @unique
  description String?
  merchantId  String?
  price       Float
  costPrice   Float
  stock       Int                       @default(0)
  minStock    Int                       @default(5)
  isActive    Boolean                   @default(true)
  isFeatured  Boolean                   @default(false)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  cartItems   CartItem[]
  acquiredBy  MerchantAcquiredProduct[]
  orderItems  OrderItem[]
  merchant    Merchant?                 @relation(fields: [merchantId], references: [id])
  categories  ProductCategory[]
  images      ProductImage[]
  variants          ProductVariant[]
  favorites         Favorite[]
  packageCategoryId String?
  packageCategory   PackageCategory? @relation(fields: [packageCategoryId], references: [id])

  @@index([merchantId])
}

model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  name      String
  price     Float?
  stock     Int     @default(0)
  isActive  Boolean @default(true)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  variantId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, variantId])
}

model Order {
  id                  String      @id @default(cuid())
  orderNumber         String      @unique
  userId              String
  addressId           String
  merchantId          String?
  status              String      @default("PENDING")
  paymentId           String?
  paymentStatus       String      @default("PENDING")
  paymentMethod       String?
  subtotal            Float
  deliveryFee         Float       @default(0)
  discount            Float       @default(0)
  total               Float
  isPickup            Boolean     @default(false)
  distanceKm          Float?
  deliveryNotes       String?
  estimatedTime       Int?
  driverId            String?
  deliveryStatus      DeliveryStatus?
  deliveredAt         DateTime?
  deliveryPhoto       String?
  customerNotes       String?
  adminNotes          String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  cancelReason        String?
  commissionPaid      Boolean     @default(false)
  driverRating        Int?
  merchantPayout      Float?      @default(0)
  moovyCommission     Float?      @default(0)
  ratedAt             DateTime?
  ratingComment       String?
  merchantRating      Int?
  merchantRatingComment String?
  sellerRating        Int?
  sellerRatingComment String?
  assignmentAttempts  Int         @default(0)
  assignmentExpiresAt DateTime?
  attemptedDriverIds  Json?
  lastAssignmentAt    DateTime?
  pendingDriverId     String?
  deletedAt           DateTime?
  address             Address     @relation(fields: [addressId], references: [id])
  driver              Driver?     @relation(fields: [driverId], references: [id])
  merchant            Merchant?   @relation(fields: [merchantId], references: [id])
  user                User        @relation(fields: [userId], references: [id])
  mpPreferenceId      String?
  mpPaymentId         String?
  mpMerchantOrderId   String?
  mpStatus            String?
  paidAt              DateTime?
  items               OrderItem[]
  subOrders           SubOrder[]
  payments            Payment[]
  assignmentLogs      AssignmentLog[]
  pendingAssignment   PendingAssignment?
  isMultiVendor       Boolean     @default(false)
  deliveryType        DeliveryType @default(IMMEDIATE)
  scheduledSlotStart  DateTime?
  scheduledSlotEnd    DateTime?
  scheduledConfirmedAt DateTime?
  couponCode          String?
  orderChats          OrderChat[]
  locationHistory     DriverLocationHistory[]

  @@index([status])
  @@index([paymentStatus])
  @@index([deliveryStatus])
  @@index([driverId])
  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId     String
  productId   String?
  listingId   String?
  name        String
  price       Float
  quantity    Int
  variantName String?
  subtotal    Float
  subOrderId  String?
  packageCategoryName String?
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id])
  listing     Listing?  @relation(fields: [listingId], references: [id])
  subOrder    SubOrder? @relation(fields: [subOrderId], references: [id])

  @@index([listingId])
}

model SubOrder {
  id                  String         @id @default(cuid())
  orderId             String
  merchantId          String?
  sellerId            String?
  status              String         @default("PENDING")
  subtotal            Float
  deliveryFee         Float          @default(0)
  discount            Float          @default(0)
  total               Float
  driverId            String?
  moovyCommission     Float?         @default(0)
  sellerPayout        Float?         @default(0)
  paymentStatus       String         @default("PENDING")
  deliveryStatus      DeliveryStatus?
  deliveredAt         DateTime?
  deliveryPhoto       String?
  driverRating        Int?
  assignmentAttempts  Int            @default(0)
  assignmentExpiresAt DateTime?
  attemptedDriverIds  Json?
  pendingDriverId     String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  order               Order          @relation(fields: [orderId], references: [id])
  merchant            Merchant?      @relation(fields: [merchantId], references: [id])
  seller              SellerProfile? @relation(fields: [sellerId], references: [id])
  driver              Driver?        @relation(fields: [driverId], references: [id])
  mpTransferId        String?
  payoutStatus        String         @default("PENDING")
  paidOutAt           DateTime?
  items               OrderItem[]

  @@index([status])
  @@index([paymentStatus])
  @@index([sellerId])
  @@index([merchantId])
}

model Merchant {
  id               String                    @id @default(cuid())
  name             String
  slug             String                    @unique
  description      String?
  image            String?
  banner           String?
  isActive         Boolean                   @default(true)
  isOpen           Boolean                   @default(true)
  scheduleEnabled  Boolean                   @default(false)
  scheduleJson     String?                   // JSON: { "1": { "open": "09:00", "close": "21:00" }, ... } (1=Mon..7=Sun, null=closed)
  isVerified       Boolean                   @default(false)
  email            String?
  phone            String?
  address          String?
  latitude         Float?
  longitude        Float?
  deliveryRadiusKm Float                     @default(5)
  deliveryTimeMin  Int                       @default(30)
  deliveryTimeMax  Int                       @default(45)
  deliveryFee      Float                     @default(0)
  minOrderAmount   Float                     @default(0)
  cuit                      String?
  constanciaAfipUrl         String?
  habilitacionMunicipalUrl  String?
  registroSanitarioUrl      String?
  acceptedTermsAt           DateTime?
  acceptedPrivacyAt         DateTime?
  category                  String?                   @default("Otro")
  ownerId          String
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  rating           Float?
  adminNotes       String?
  bankAccount      String?
  businessName     String?
  commissionRate   Float                     @default(8)
  cuil             String?
  displayOrder     Int                       @default(0)
  facebookUrl      String?
  instagramUrl     String?
  isPremium        Boolean                   @default(false)
  ownerBirthDate   DateTime?
  ownerDni         String?
  premiumTier      String?                   @default("basic")
  premiumUntil     DateTime?
  startedAt        DateTime?
  whatsappNumber   String?
  mpAccessToken    String?
  mpRefreshToken   String?
  mpUserId         String?                   @unique
  mpEmail          String?
  mpLinkedAt       DateTime?
  approvalStatus   String                    @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedAt       DateTime?
  rejectionReason  String?
  ubicacion        Unsupported("geography")?
  // Merchant Loyalty Program
  loyaltyTier      String                    @default("BRONCE") // BRONCE | PLATA | ORO | DIAMANTE
  loyaltyOrderCount Int                      @default(0) // Orders in current 30-day period
  loyaltyUpdatedAt DateTime                  @default(now()) // Last time tier was recalculated
  owner            User                      @relation(fields: [ownerId], references: [id])
  acquiredProducts MerchantAcquiredProduct[]
  categories       MerchantCategory[]
  packagePurchases PackagePurchase[]
  orders           Order[]
  products         Product[]
  subOrders        SubOrder[]
  favorites        Favorite[]

  @@index([isActive])
  @@index([ownerId])
  @@index([approvalStatus])
  @@index([loyaltyTier])
}

model MerchantLoyaltyConfig {
  id                String   @id @default(cuid())
  tier              String   @unique // BRONCE | PLATA | ORO | DIAMANTE
  minOrdersPerMonth Int // Minimum orders to qualify
  commissionRate    Float // Commission % (e.g., 8, 7, 6, 5)
  badgeText         String // "Destacado", "Popular", "Elite"
  badgeColor        String   @default("gray") // bg color: gray, blue, yellow, purple
  benefitsJson      String   @default("{}") // JSON array of benefit descriptions
  displayOrder      Int      @default(0) // For UI ordering
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tier])
}

model Driver {
  id                 String                    @id @default(cuid())
  userId             String                    @unique
  vehicleType        String?
  vehicleBrand       String?
  vehicleModel       String?
  vehicleYear        Int?
  vehicleColor       String?
  licensePlate       String?
  cuit               String?
  licenciaUrl        String?
  seguroUrl          String?
  vtvUrl             String?
  dniFrenteUrl       String?
  dniDorsoUrl        String?
  acceptedTermsAt    DateTime?
  isActive           Boolean                   @default(true)
  isOnline           Boolean                   @default(false)
  totalDeliveries    Int                       @default(0)
  rating             Float?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  availabilityStatus String                    @default("FUERA_DE_SERVICIO")
  lastLocationAt     DateTime?
  latitude           Float?
  longitude          Float?
  approvalStatus     String                    @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedAt         DateTime?
  rejectionReason    String?
  ubicacion          Unsupported("geography")?
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders              Order[]
  subOrders           SubOrder[]
  assignmentLogs      AssignmentLog[]
  locationHistory     DriverLocationHistory[]

  @@index([isOnline])
  @@index([isActive])
  @@index([approvalStatus])
}

model DriverLocationHistory {
  id        String   @id @default(cuid())
  driverId  String
  orderId   String?  // nullable — track even when idle
  latitude  Float
  longitude Float
  accuracy  Float?
  speed     Float?
  heading   Float?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([driverId, createdAt])
  @@index([orderId, createdAt])
  @@index([timestamp])
}

model SellerProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  displayName    String?
  bio            String?
  avatar         String?
  cuit           String?
  acceptedTermsAt DateTime?
  bankAlias      String?
  bankCbu        String?
  isActive       Boolean   @default(true)
  isVerified     Boolean   @default(false)
  totalSales     Int       @default(0)
  rating         Float?
  commissionRate Float     @default(12)
  mpAccessToken  String?
  mpRefreshToken String?
  mpUserId       String?   @unique
  mpEmail        String?
  mpLinkedAt     DateTime?
  scheduleEnabled Boolean    @default(false)
  scheduleJson   String?     // JSON: { "1": { "open": "09:00", "close": "21:00" }, ... } (1=Mon..7=Sun, null=closed)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])
  listings       Listing[]
  subOrders      SubOrder[]
}

model Listing {
  id          String         @id @default(cuid())
  sellerId    String
  title       String
  description String?
  price       Float
  stock       Int            @default(1)
  condition   String         @default("NUEVO")
  weightKg    Float?
  lengthCm    Float?
  widthCm     Float?
  heightCm    Float?
  isActive    Boolean        @default(true)
  categoryId  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  seller      SellerProfile  @relation(fields: [sellerId], references: [id])
  images      ListingImage[]
  category    Category?      @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  favorites   Favorite[]

  @@index([isActive])
  @@index([sellerId])
  @@index([categoryId])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  url       String
  order     Int     @default(0)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model StoreSettings {
  id                    String   @id @default("settings")
  isOpen                Boolean  @default(true)
  closedMessage         String   @default("Estamos cerrados. ??Volvemos pronto!")
  isMaintenanceMode     Boolean  @default(false)
  maintenanceMessage    String   @default("??Volvemos pronto! Estamos trabajando para mejorar tu experiencia.")
  fuelPricePerLiter     Float    @default(1200)
  fuelConsumptionPerKm  Float    @default(0.06)
  baseDeliveryFee       Float    @default(500)
  maintenanceFactor     Float    @default(1.35)
  freeDeliveryMinimum   Float?
  maxDeliveryDistance   Float    @default(15)
  storeName             String   @default("Moovy Ushuaia")
  storeAddress          String   @default("Ushuaia, Tierra del Fuego")
  originLat             Float    @default(-54.8019)
  originLng             Float    @default(-68.3030)
  whatsappNumber        String?
  phone                 String?
  email                 String?
  schedule              String?
  updatedAt             DateTime @updatedAt
  promoPopupButtonText  String?  @default("Ver m??s")
  promoPopupDismissable Boolean  @default(true)
  promoPopupEnabled     Boolean  @default(false)
  promoPopupImage       String?
  promoPopupLink        String?
  promoPopupMessage     String?
  promoPopupTitle       String?
  showComerciosCard     Boolean  @default(true)
  showRepartidoresCard  Boolean  @default(true)
  tiendaMaintenance     Boolean  @default(false)
  maxCategoriesHome     Int      @default(6)
  heroSliderEnabled     Boolean  @default(true)
  heroSliderInterval    Int      @default(5000)
  promoBannerButtonLink String   @default("/productos?categoria=pizzas")
  promoBannerButtonText String   @default("Ver locales")
  promoBannerEnabled    Boolean  @default(true)
  promoBannerImage      String?
  promoBannerSubtitle   String   @default("2x1 en locales seleccionados de 20hs a 23hs.")
  promoBannerTitle      String   @default("Noches de\nPizza & Pelis")
  promoBannerCtaPosition String  @default("abajo-izquierda")
  riderCommissionPercent Float   @default(80)

  // === OPS CONFIG: Delivery Zones & Climate (Biblia Financiera) ===
  zoneMultipliersJson      String  @default("{\"ZONA_A\":1.0,\"ZONA_B\":1.15,\"ZONA_C\":1.35}")
  climateMultipliersJson   String  @default("{\"normal\":1.0,\"lluvia\":1.10,\"nieve\":1.15,\"extremo\":1.25}")
  activeClimateCondition   String  @default("normal")
  operationalCostPercent   Float   @default(5)

  // === OPS CONFIG: Commission defaults ===
  defaultMerchantCommission Float  @default(8)
  defaultSellerCommission   Float  @default(12)

  // === OPS CONFIG: Cash Protocol ===
  cashMpOnlyDeliveries     Int     @default(10)
  cashLimitL1              Float   @default(15000)
  cashLimitL2              Float   @default(25000)
  cashLimitL3              Float   @default(40000)

  // === OPS CONFIG: Scheduled Delivery ===
  maxOrdersPerSlot         Int     @default(15)
  slotDurationMinutes      Int     @default(120)
  minAnticipationHours     Float   @default(1.5)
  maxAnticipationHours     Float   @default(48)
  operatingHoursStart      String  @default("09:00")
  operatingHoursEnd        String  @default("22:00")

  // === OPS CONFIG: Timeouts ===
  merchantConfirmTimeoutSec Int    @default(300)
  driverResponseTimeoutSec  Int    @default(60)

  // === OPS CONFIG: Advertising Pricing (Biblia Financiera) ===
  adPricePlatino         Float   @default(150000)
  adPriceDestacado       Float   @default(95000)
  adPricePremium         Float   @default(55000)
  adPriceHeroBanner      Float   @default(250000)
  adPriceBannerPromo     Float   @default(180000)
  adPriceProducto        Float   @default(25000)
  adLaunchDiscountPercent Float  @default(50)
  adMaxHeroBannerSlots   Int     @default(3)
  adMaxDestacadosSlots   Int     @default(8)
  adMaxProductosSlots    Int     @default(12)
}

model PointsConfig {
  id                   String   @id @default("points_config")
  pointsPerDollar      Float    @default(1)
  minPurchaseForPoints Float    @default(0)
  pointsValue          Float    @default(0.01)
  minPointsToRedeem    Int      @default(100)
  maxDiscountPercent   Float    @default(50)
  signupBonus          Int      @default(100)
  referralBonus        Int      @default(200)
  reviewBonus          Int      @default(10)
  pointsExpireDays     Int?
  refereeBonus         Int      @default(100)
  minPurchaseForBonus  Float    @default(5000)
  minReferralPurchase  Float    @default(8000)
  tierWindowDays       Int      @default(90)
  tierConfigJson       String?
  updatedAt            DateTime @updatedAt
}

model PointsTransaction {
  id           String   @id @default(cuid())
  userId       String
  orderId      String?
  type         String
  amount       Int
  balanceAfter Int
  description  String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  refereeId      String   @unique
  codeUsed       String
  referrerPoints Int      @default(50)
  refereePoints  Int      @default(100)
  status         String   @default("COMPLETED")
  createdAt      DateTime @default(now())
  referee        User     @relation("ReferralReferee", fields: [refereeId], references: [id], onDelete: Cascade)
  referrer       User     @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
}

model SavedCart {
  id         String   @id @default(cuid())
  userId     String   @unique
  items      Json
  merchantId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SupportChat {
  id            String           @id @default(cuid())
  userId        String
  merchantId    String?
  operatorId    String?
  subject       String?
  category      String?          // "pedido", "pago", "cuenta", "comercio", "repartidor", "otro"
  status        String           @default("waiting") // waiting, active, resolved, closed
  priority      String           @default("normal")  // low, normal, high, urgent
  rating        Int?             // 1-5 post-chat rating
  ratingComment String?
  lastMessageAt DateTime         @default(now())
  resolvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation("UserSupportChats", fields: [userId], references: [id], onDelete: Cascade)
  operator      SupportOperator? @relation(fields: [operatorId], references: [id])
  messages      SupportMessage[]

  @@index([userId])
  @@index([operatorId])
  @@index([status])
  @@index([createdAt])
}

model SupportMessage {
  id              String      @id @default(cuid())
  chatId          String
  senderId        String
  content         String
  isFromAdmin     Boolean     @default(false)
  isSystem        Boolean     @default(false) // system messages like "operator joined"
  isRead          Boolean     @default(false)
  attachmentUrl   String?
  attachmentType  String?     // "image", "file"
  createdAt       DateTime    @default(now())
  chat            SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender          User        @relation("SupportMessageSender", fields: [senderId], references: [id])

  @@index([chatId])
  @@index([createdAt])
}

model SupportOperator {
  id          String        @id @default(cuid())
  userId      String        @unique
  displayName String
  isActive    Boolean       @default(true)  // admin can enable/disable
  isOnline    Boolean       @default(false) // operator toggles
  maxChats    Int           @default(5)     // max concurrent chats
  lastSeenAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chats       SupportChat[]

  @@index([isActive, isOnline])
}

model CannedResponse {
  id        String   @id @default(cuid())
  shortcut  String   @unique // e.g. "/saludo", "/horario", "/pago"
  title     String            // display name: "Saludo inicial"
  content   String            // full response text
  category  String            // "general", "pedido", "pago", "cuenta", "cierre"
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model OrderBackup {
  id          String   @id @default(cuid())
  backupName  String
  orderData   String
  orderId     String?
  orderNumber String?
  total       Float?
  deletedBy   String?
  deletedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([backupName])
  @@index([deletedAt])
  @@index([orderId])
}

model Favorite {
  id         String    @id @default(cuid())
  userId     String
  merchantId String?
  productId  String?
  listingId  String?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant   Merchant? @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  product    Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  listing    Listing?  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantId])
  @@unique([userId, productId])
  @@unique([userId, listingId])
  @@index([userId])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model MerchantCategory {
  id         String   @id @default(cuid())
  merchantId String
  categoryId String
  createdAt  DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, categoryId])
}

model MerchantAcquiredProduct {
  id         String   @id @default(cuid())
  merchantId String
  productId  String
  createdAt  DateTime @default(now())
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([merchantId, productId])
}

// Paquetes B2B — registro de compras de catálogos por comercios
model PackagePurchase {
  id              String    @id @default(cuid())
  merchantId      String
  // What was purchased
  purchaseType    String    // "package" | "starter" | "custom" | "individual"
  categoryId      String?   // For package/starter purchases
  productIds      String?   // JSON array of product IDs for custom/individual
  itemCount       Int       @default(0)
  // Pricing
  amount          Float
  currency        String    @default("ARS")
  // Payment
  paymentStatus   String    @default("pending") // pending | approved | rejected | refunded
  paymentMethod   String?   // mercadopago | free | promo
  mpPreferenceId  String?
  mpPaymentId     String?
  mpExternalRef   String?   @unique
  // Import status
  importStatus    String    @default("pending") // pending | imported | failed
  importedCount   Int       @default(0)
  importedAt      DateTime?
  // Metadata
  promoCode       String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  merchant Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([merchantId])
  @@index([paymentStatus])
  @@index([mpExternalRef])
}

// Precios escalonados para compra custom de productos individuales
model PackagePricingTier {
  id          String @id @default(cuid())
  name        String // "Pack x10", "Pack x25", "Pack x50"
  minItems    Int    // Mínimo de items (10, 25, 50)
  maxItems    Int?   // Máximo (null = ilimitado)
  pricePerItem Float // Precio por item en este tier
  totalPrice  Float  // Precio total del pack
  isActive    Boolean @default(true)
  order       Int     @default(0)
  createdAt   DateTime @default(now())
}

model Payment {
  id             String   @id @default(cuid())
  orderId        String
  mpPaymentId    String   @unique
  mpStatus       String
  mpStatusDetail String?
  amount         Float
  currency       String   @default("ARS")
  payerEmail     String?
  paymentMethod  String?
  rawPayload     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([mpPaymentId])
}

model MpWebhookLog {
  id         String   @id @default(cuid())
  eventId    String   @unique
  eventType  String
  resourceId String
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([resourceId])
}

// ─── Delivery & Assignment System ─────────────────────────────────────────────

enum VehicleTypeEnum {
  BIKE
  MOTO
  CAR
  TRUCK
}

enum AssignmentOutcomeEnum {
  ACCEPTED
  REJECTED
  TIMEOUT
  SKIPPED
}

enum PendingAssignmentStatus {
  WAITING
  COMPLETED
  FAILED
}

model PackageCategory {
  id              String   @id @default(cuid())
  name            String   @unique // MICRO, SMALL, MEDIUM, LARGE, XL
  maxWeightGrams  Int
  maxLengthCm     Int
  maxWidthCm      Int
  maxHeightCm     Int
  volumeScore     Int      // MICRO=1, SMALL=3, MEDIUM=6, LARGE=10, XL=20
  allowedVehicles String[] // enum values: BIKE, MOTO, CAR, TRUCK
  isActive        Boolean  @default(true)
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deliveryRate DeliveryRate?
  products     Product[]
}

model DeliveryRate {
  id             String          @id @default(cuid())
  categoryId     String          @unique
  basePriceArs   Float
  pricePerKmArs  Float
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  category PackageCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model MoovyConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String
  updatedAt   DateTime @updatedAt
}

model AssignmentLog {
  id            String                @id @default(cuid())
  orderId       String
  driverId      String
  attemptNumber Int                   @default(1)
  notifiedAt    DateTime              @default(now())
  respondedAt   DateTime?
  outcome       AssignmentOutcomeEnum @default(ACCEPTED)
  distanceKm    Float?

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([driverId])
  @@index([notifiedAt])
}

model PendingAssignment {
  id              String                  @id @default(cuid())
  orderId         String                  @unique
  currentDriverId String?
  attemptNumber   Int                     @default(1)
  expiresAt       DateTime
  status          PendingAssignmentStatus @default(WAITING)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([expiresAt])
}

model SellerAvailability {
  id                  String    @id @default(cuid())
  sellerId            String    @unique
  isOnline            Boolean   @default(false)
  isPaused            Boolean   @default(false)
  pauseEndsAt         DateTime?
  preparationMinutes  Int       @default(15)
  scheduleEnabled     Boolean   @default(false)
  scheduleJson        String?   // stores recurring schedule as JSON string
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "ORDER_STATUS_CHANGE", "REFUND", "DRIVER_REASSIGN", "COMMISSION_PAID"
  entityType String  // e.g. "Order", "Merchant", "Driver", "Listing"
  entityId  String
  userId    String   // admin who performed the action
  details   String?  // JSON string with before/after or extra context
  createdAt DateTime @default(now())

  user User @relation("AuditLogs", fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model Coupon {
  id               String        @id @default(cuid())
  code             String        @unique
  description      String?
  discountType     String        @default("PERCENTAGE") // PERCENTAGE | FIXED_AMOUNT | FREE_DELIVERY
  discountValue    Float
  maxDiscountAmount Float?
  minOrderAmount   Float?
  maxUses          Int?
  maxUsesPerUser   Int           @default(1)
  usedCount        Int           @default(0)
  isActive         Boolean       @default(true)
  validFrom        DateTime      @default(now())
  validUntil       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  usages           CouponUsage[]

  @@index([code])
  @@index([isActive])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String?
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([couponId])
  @@index([userId])
}

